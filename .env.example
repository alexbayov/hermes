# Hermes Agent Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM PROVIDER (OpenRouter)
# =============================================================================
# OpenRouter provides access to many models through one API
# All LLM calls go through OpenRouter - no direct provider keys needed
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Fireworks AI API Key (Primary Provider)
FIREWORKS_API_KEY=your_fireworks_key_here

# OpenAI-compatible endpoint configuration (used for Fireworks)
OPENAI_API_KEY=your_fireworks_key_here

# =============================================================================
# FIREWORKS API KEY ROTATION (5 accounts with attached cards)
# =============================================================================
# Add backup keys here for rotation
